---
import Layout from '../layouts/Layout.astro';
import { i18n } from '../i18n';

export interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const t = i18n[lang];
---

<Layout title={`Glaspen2 — ${t.hero.subtitle}`}>
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-black/30 backdrop-blur-md border-b border-white/10">
    <div class="max-w-4xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href={lang === 'zh' ? '/' : '/en/'} class="flex items-center gap-2 text-lg font-semibold text-white">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/70">
          <path d="M14 7l4-4 4 4" />
        </svg>
        Glaspen2
      </a>
      <div class="flex items-center gap-6 text-sm text-white/70">
        <a href={lang === 'zh' ? '/#features' : '/en/#features'} class="hover:text-white transition">{t.nav.features}</a>
        <a href={lang === 'zh' ? '/#shortcuts' : '/en/#shortcuts'} class="hover:text-white transition">{t.nav.shortcuts}</a>
        <a href={lang === 'zh' ? '/#download' : '/en/#download'} class="hover:text-white transition">{t.nav.download}</a>
        <a href="https://github.com/yourname/glaspen2" target="_blank" rel="noopener" class="hover:text-white transition">{t.nav.github}</a>
        <span class="text-white/20">|</span>
        {lang === 'zh'
          ? <a href="/en/" class="text-white font-medium hover:text-white/70 transition">EN</a>
          : <a href="/" class="text-white font-medium hover:text-white/70 transition">中</a>
        }
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="min-h-screen flex flex-col items-center justify-center px-6 pt-14">
    <div class="text-center max-w-2xl animate-fade-in">
      <div class="mb-8 flex justify-center">
        <img src="/icon.svg" alt="Glaspen2" width="80" height="80" />
      </div>

      <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-white mb-3">
        Glaspen2
      </h1>
      <p class="text-xl md:text-2xl text-white/80 font-light mb-2">
        {t.hero.subtitle}
      </p>
      <p class="text-base text-white/60 max-w-md mx-auto mb-10 leading-relaxed" set:html={t.hero.description}>
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={lang === 'zh' ? '/#download' : '/en/#download'}
           class="inline-flex items-center gap-2 px-8 py-3 rounded-lg bg-white/20 hover:bg-white/30 backdrop-blur-sm text-white font-medium transition-all shadow-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          {t.hero.download}
        </a>
        <a href={lang === 'zh' ? '/#features' : '/en/#features'}
           class="inline-flex items-center gap-2 px-8 py-3 rounded-lg border border-white/30 hover:border-white/60 text-white/80 hover:text-white font-medium transition-all">
          {t.hero.learnMore}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="7 13 12 18 17 13" />
            <line x1="12" y1="6" x2="12" y2="18" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Demo GIF -->
    <div class="mt-16 w-full max-w-2xl animate-slide-up rounded-lg border border-white/20 overflow-hidden shadow-sm" style="animation-delay: 0.15s">
      <img src="/demo.gif" alt="Demo" class="w-full" />
    </div>
  </section>

  <!-- Features List -->
  <section id="features" class="py-24 px-6 bg-black/40 backdrop-blur-sm">
    <div class="max-w-3xl mx-auto">
      <div class="mb-16">
        <p class="text-sm font-medium text-white/60 uppercase tracking-widest mb-2">{t.features.tag}</p>
        <h2 class="text-3xl font-bold text-white">{t.features.title}</h2>
      </div>

      <div class="space-y-0 divide-y divide-white/10">
        {t.features.items.map((item) => (
          <div class="py-8 flex gap-6">
            <div class="shrink-0 w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center mt-0.5">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/70">
                <path d="M20 14.66V20a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2h5.34" />
                <polygon points="18 2 22 6 12 16 8 16 8 12 18 2" />
              </svg>
            </div>
            <div class="min-w-0">
              <h3 class="text-base font-semibold text-white mb-1">{item.title}</h3>
              <p class="text-sm text-white/60 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Handwritten Messages Showcase -->
  <section class="py-24 px-6 bg-black/20 backdrop-blur-sm">
    <div class="max-w-3xl mx-auto">
      <div class="mb-12">
        <p class="text-sm font-medium text-white/60 uppercase tracking-widest mb-2">{t.showcase.tag}</p>
        <h2 class="text-3xl font-bold text-white">{t.showcase.title}</h2>
        <p class="mt-2 text-white/50">{t.showcase.desc}</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="rounded-lg border border-white/20 overflow-hidden">
          <img src="/chat.jpg" alt="Chat example" class="w-full" />
        </div>
        <div class="rounded-lg border border-white/20 overflow-hidden">
          <img src="/converted.gif" alt="Converted sticker" class="w-full" />
        </div>
      </div>
    </div>
  </section>

  <!-- Keyboard Shortcuts -->
  <section id="shortcuts" class="py-24 px-6 bg-black/40 backdrop-blur-sm">
    <div class="max-w-3xl mx-auto">
      <div class="mb-12">
        <p class="text-sm font-medium text-white/60 uppercase tracking-widest mb-2">{t.shortcuts.tag}</p>
        <h2 class="text-3xl font-bold text-white">{t.shortcuts.title}</h2>
        <p class="mt-2 text-white/50">{t.shortcuts.desc}</p>
      </div>

      <div class="overflow-hidden rounded-lg border border-white/10 bg-white/5 backdrop-blur-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/10 bg-white/5">
              <th class="text-left py-3 px-5 font-medium text-white/60">{t.nav.features}</th>
              <th class="text-left py-3 px-5 font-medium text-white/60">macOS</th>
              <th class="text-left py-3 px-5 font-medium text-white/60">Windows</th>
            </tr>
          </thead>
          <tbody>
            {t.shortcuts.rows.map((row) => (
              <tr class="border-b border-white/5 last:border-b-0">
                <td class="py-3 px-5 text-white/80">{row.func}</td>
                <td class="py-3 px-5">
                  {row.mac !== '—' && row.mac ? (
                    <kbd class="px-2 py-0.5 rounded bg-white/10 text-xs font-mono text-white/70">{row.mac}</kbd>
                  ) : (
                    <span class="text-white/30">—</span>
                  )}
                </td>
                <td class="py-3 px-5">
                  {row.win ? (
                    <kbd class="px-2 py-0.5 rounded bg-white/10 text-xs font-mono text-white/70">{row.win}</kbd>
                  ) : (
                    <span class="text-white/30">—</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Download -->
  <section id="download" class="py-24 px-6 bg-black/20 backdrop-blur-sm">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-medium text-white/60 uppercase tracking-widest mb-2">{t.download.tag}</p>
      <h2 class="text-3xl font-bold text-white mb-2">{t.download.title}</h2>
      <p class="text-white/50 mb-10">{t.download.desc}</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/download"
           class="inline-flex items-center gap-3 px-8 py-3.5 rounded-lg bg-white/20 hover:bg-white/30 backdrop-blur-sm text-white font-medium transition-all shadow-sm">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2v12m0 0l-3-3m3 3l3-3" />
            <path d="M2 16v3a2 2 0 002 2h16a2 2 0 002-2v-3" />
          </svg>
          <div class="text-left">
            <div class="text-xs text-white/50 font-normal">{t.download.downloadLabel}</div>
            <div>{t.download.macOS}</div>
          </div>
        </a>
        <a href="/download"
           class="inline-flex items-center gap-3 px-8 py-3.5 rounded-lg border border-white/30 hover:border-white/60 text-white/80 hover:text-white font-medium transition-all backdrop-blur-sm">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="4" y="2" width="16" height="20" rx="2" />
            <line x1="9" y1="6" x2="15" y2="6" />
          </svg>
          <div class="text-left">
            <div class="text-xs text-white/50 font-normal">{t.download.downloadLabel}</div>
            <div>{t.download.windows}</div>
          </div>
        </a>
      </div>

      <p class="mt-6 text-sm text-white/30">
        {t.download.requirements}
      </p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-white/10 py-10 px-6 bg-black/30 backdrop-blur-sm">
    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3 text-sm text-white/40">
      <div class="flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/50">
          <path d="M3 17l6-6 4 4 8-8" />
          <path d="M14 7l4-4 4 4" />
        </svg>
        Glaspen2
      </div>
      <div class="flex items-center gap-5">
        <a href="https://github.com/yourname/glaspen2" target="_blank" rel="noopener" class="hover:text-white/60 transition">{t.nav.github}</a>
        <a href="https://github.com/yourname/glaspen2/releases" target="_blank" rel="noopener" class="hover:text-white/60 transition">{t.footer.releases}</a>
      </div>
      <div class="text-xs">
        {t.footer.builtWith}
      </div>
    </div>
  </footer>
</Layout>
